# Reverse proxy for the deployed VM. Caddy terminates TLS (auto Let's Encrypt)
# on :443 and routes the public API hostname to the internal Go service over the
# compose network.
#
# pyworker (embeddings/rerank) is intentionally NOT exposed publicly — api reaches
# it in-cluster at http://pyworker:8090. If you ever need to hit it from outside,
# use an SSH tunnel rather than a public route.
#
# The api DNS A-record must point at the VM public IP before Caddy can obtain a
# certificate (HTTP-01 challenge on :80).
api-nornikel.rmdigital.ru {
	reverse_proxy api:8080
}
