YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Public deployment only (VM): strong DB password (port 5435 is internet-facing)
# and the Caddy basic-auth bcrypt hash for the embeddings endpoint. Leave empty
# for local dev — the stack falls back to `postgres` / no proxy.
# POSTGRES_PASSWORD=
# EMBEDDINGS_PW_HASH=
# Optional overrides
# YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt/latest
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/hypothesis_factory?sslmode=disable
# WORKER_BASE_URL=http://localhost:8090
# PORT=8080
